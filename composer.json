{
    "name": "jklejczyk/tpm-core",
    "description": "TPM domain library",
    "version": "1.0.0",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Tpm\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Jakub Klejczyk",
            "email": "jklejczyk@gmail.com"
        }
    ],
    "require": { "php": "^8.3" },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "phpstan/phpstan": "^2.0",
        "deptrac/deptrac": "^2.0"
    },
    "scripts": {
        "check": ["pest", "phpstan analyse", "deptrac analyse"]
    },
    "config": {
        "allow-plugins": { "pestphp/pest-plugin": true },
        "sort-packages": true,
        "platform": { "php": "8.3.0" }
    },
    "minimum-stability": "stable"
}
