{
    "name": "jklejczyk/tpm-core",
    "description": "TPM domain library",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Tpm\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Jakub Klejczyk",
            "email": "jklejczyk@gmail.com"
        }
    ],
    "require": { "php": "^8.3" },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "phpstan/phpstan": "^2.0",
        "deptrac/deptrac": "^2.0"
    },
    "scripts": {
        "test": "pest",
        "stan": "phpstan analyse src --level=9",
        "deptrac": "deptrac analyse",
        "check": ["@test", "@stan", "@deptrac"]
    },
    "config": {
        "allow-plugins": { "pestphp/pest-plugin": true },
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
